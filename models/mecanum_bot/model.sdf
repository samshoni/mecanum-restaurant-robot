<?xml version="1.0" ?>
<!--
  Mecanum Bot — Restaurant Food Delivery Robot
  Ignition Gazebo Fortress

  Robot proportions (world frame, robot spawned at z=0):
    Chassis:     z=0.10–0.20 m  (centre at 0.15, base_link origin)
    Pillars:     z=0.20–0.78 m  (two white vertical columns at y=±0.125)
    Shelf 1:     z≈0.27 m       (lowest food tray)
    Shelf 2:     z≈0.46 m       (middle food tray)
    Shelf 3:     z≈0.65 m       (upper food tray)
    Head:        z=0.76–0.96 m  (display + "face")
    LiDAR:       z≈0.98 m       (on top of head)
    Total height ≈ 1.02 m

  Visual poses are in BASE_LINK LOCAL FRAME (base_link at model z=0.15).
  Wheel physics: sphere collision + anisotropic ODE friction (unchanged).

  Roller type per wheel:
    FL (front-left)  : left=True  fdir1= 1 -1  0   "/"
    FR (front-right) : left=False fdir1= 1  1  0   "\"
    RL (rear-left)   : left=False fdir1= 1  1  0   "\"
    RR (rear-right)  : left=True  fdir1= 1 -1  0   "/"
-->
<sdf version="1.6">
  <model name="mecanum_bot" xmlns:ignition="http://ignitionrobotics.org/schema">

    <!-- ════════════════════════════════════════════════════════════
         CHASSIS  (base_link centre = model frame z=0.15)
         All visual <pose> values are in base_link LOCAL frame.
    ════════════════════════════════════════════════════════════ -->
    <link name="base_link">
      <pose>0 0 0.15 0 0 0</pose>
      <inertial>
        <mass>15.0</mass>
        <inertia>
          <ixx>1.40</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1.56</iyy><iyz>0</iyz><izz>0.47</izz>
        </inertia>
      </inertial>

      <!-- ── Chassis body — dark charcoal ───────────────────── -->
      <visual name="chassis">
        <geometry><box><size>0.50 0.35 0.10</size></box></geometry>
        <material>
          <ambient>0.18 0.18 0.18 1</ambient>
          <diffuse>0.20 0.20 0.20 1</diffuse>
          <specular>0.30 0.30 0.30 1</specular>
        </material>
      </visual>

      <!-- Chassis top plate — slightly darker -->
      <visual name="chassis_top">
        <pose>0 0 0.056 0 0 0</pose>
        <geometry><box><size>0.46 0.31 0.012</size></box></geometry>
        <material>
          <ambient>0.10 0.10 0.10 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.15 0.15 0.15 1</specular>
        </material>
      </visual>

      <!-- Front accent strip — white -->
      <visual name="front_strip">
        <pose>0.252 0 0 0 0 0</pose>
        <geometry><box><size>0.004 0.35 0.10</size></box></geometry>
        <material>
          <ambient>0.90 0.90 0.90 1</ambient>
          <diffuse>0.90 0.90 0.90 1</diffuse>
        </material>
      </visual>

      <!-- Rear accent strip — white -->
      <visual name="rear_strip">
        <pose>-0.252 0 0 0 0 0</pose>
        <geometry><box><size>0.004 0.35 0.10</size></box></geometry>
        <material>
          <ambient>0.90 0.90 0.90 1</ambient>
          <diffuse>0.90 0.90 0.90 1</diffuse>
        </material>
      </visual>

      <!-- ── Vertical pillars — pure white ──────────────────────
           BL z=0.34, h=0.58 → world z=0.20 to 0.78 m
      ─────────────────────────────────────────────────────────── -->
      <visual name="pillar_left">
        <pose>0 0.125 0.34 0 0 0</pose>
        <geometry><box><size>0.06 0.05 0.58</size></box></geometry>
        <material>
          <ambient>0.94 0.94 0.94 1</ambient>
          <diffuse>0.94 0.94 0.94 1</diffuse>
          <specular>0.70 0.70 0.70 1</specular>
        </material>
      </visual>

      <visual name="pillar_right">
        <pose>0 -0.125 0.34 0 0 0</pose>
        <geometry><box><size>0.06 0.05 0.58</size></box></geometry>
        <material>
          <ambient>0.94 0.94 0.94 1</ambient>
          <diffuse>0.94 0.94 0.94 1</diffuse>
          <specular>0.70 0.70 0.70 1</specular>
        </material>
      </visual>

      <!-- ── SHELF 1 — world z≈0.27 m (BL z=0.12) ─────────────
           Tray: 0.38 × 0.30 × 0.012
           Lips: front (x+) and back (x-), 0.030 m tall
      ─────────────────────────────────────────────────────────── -->
      <visual name="shelf1_tray">
        <pose>0 0 0.12 0 0 0</pose>
        <geometry><box><size>0.38 0.30 0.012</size></box></geometry>
        <material>
          <ambient>0.92 0.90 0.85 1</ambient>
          <diffuse>0.92 0.90 0.85 1</diffuse>
          <specular>0.50 0.50 0.45 1</specular>
        </material>
      </visual>
      <!-- front lip: tray top = 0.126, lip half-h = 0.015, lip centre z=0.141 -->
      <visual name="shelf1_lip_front">
        <pose>0.194 0 0.141 0 0 0</pose>
        <geometry><box><size>0.008 0.30 0.030</size></box></geometry>
        <material>
          <ambient>0.85 0.83 0.78 1</ambient>
          <diffuse>0.85 0.83 0.78 1</diffuse>
        </material>
      </visual>
      <visual name="shelf1_lip_back">
        <pose>-0.194 0 0.141 0 0 0</pose>
        <geometry><box><size>0.008 0.30 0.030</size></box></geometry>
        <material>
          <ambient>0.85 0.83 0.78 1</ambient>
          <diffuse>0.85 0.83 0.78 1</diffuse>
        </material>
      </visual>

      <!-- ── SHELF 2 — world z≈0.46 m (BL z=0.31) ─────────────  -->
      <visual name="shelf2_tray">
        <pose>0 0 0.31 0 0 0</pose>
        <geometry><box><size>0.38 0.30 0.012</size></box></geometry>
        <material>
          <ambient>0.92 0.90 0.85 1</ambient>
          <diffuse>0.92 0.90 0.85 1</diffuse>
          <specular>0.50 0.50 0.45 1</specular>
        </material>
      </visual>
      <visual name="shelf2_lip_front">
        <pose>0.194 0 0.331 0 0 0</pose>
        <geometry><box><size>0.008 0.30 0.030</size></box></geometry>
        <material>
          <ambient>0.85 0.83 0.78 1</ambient>
          <diffuse>0.85 0.83 0.78 1</diffuse>
        </material>
      </visual>
      <visual name="shelf2_lip_back">
        <pose>-0.194 0 0.331 0 0 0</pose>
        <geometry><box><size>0.008 0.30 0.030</size></box></geometry>
        <material>
          <ambient>0.85 0.83 0.78 1</ambient>
          <diffuse>0.85 0.83 0.78 1</diffuse>
        </material>
      </visual>

      <!-- ── SHELF 3 — world z≈0.65 m (BL z=0.50) ─────────────  -->
      <visual name="shelf3_tray">
        <pose>0 0 0.50 0 0 0</pose>
        <geometry><box><size>0.38 0.30 0.012</size></box></geometry>
        <material>
          <ambient>0.92 0.90 0.85 1</ambient>
          <diffuse>0.92 0.90 0.85 1</diffuse>
          <specular>0.50 0.50 0.45 1</specular>
        </material>
      </visual>
      <visual name="shelf3_lip_front">
        <pose>0.194 0 0.521 0 0 0</pose>
        <geometry><box><size>0.008 0.30 0.030</size></box></geometry>
        <material>
          <ambient>0.85 0.83 0.78 1</ambient>
          <diffuse>0.85 0.83 0.78 1</diffuse>
        </material>
      </visual>
      <visual name="shelf3_lip_back">
        <pose>-0.194 0 0.521 0 0 0</pose>
        <geometry><box><size>0.008 0.30 0.030</size></box></geometry>
        <material>
          <ambient>0.85 0.83 0.78 1</ambient>
          <diffuse>0.85 0.83 0.78 1</diffuse>
        </material>
      </visual>

      <!-- ── HEAD — world z=0.76–0.96 m (BL z centre=0.71) ─────
           White rounded-look block: 0.34 × 0.28 × 0.20
      ─────────────────────────────────────────────────────────── -->
      <visual name="head_body">
        <pose>0 0 0.71 0 0 0</pose>
        <geometry><box><size>0.34 0.28 0.20</size></box></geometry>
        <material>
          <ambient>0.96 0.96 0.96 1</ambient>
          <diffuse>0.96 0.96 0.96 1</diffuse>
          <specular>0.80 0.80 0.80 1</specular>
        </material>
      </visual>

      <!-- Display panel — deep blue, front face of head (x=+0.171) -->
      <visual name="head_display">
        <pose>0.171 0 0.71 0 0 0</pose>
        <geometry><box><size>0.004 0.26 0.16</size></box></geometry>
        <material>
          <ambient>0.04 0.28 0.70 1</ambient>
          <diffuse>0.05 0.32 0.75 1</diffuse>
          <specular>0.20 0.50 0.90 1</specular>
          <emissive>0.01 0.06 0.18 1</emissive>
        </material>
      </visual>

      <!-- Eye left — cyan disc, rotated so flat face shows forward -->
      <visual name="eye_left">
        <pose>0.174 0.07 0.755 0 1.5707 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.006</length></cylinder></geometry>
        <material>
          <ambient>0.0 0.85 0.95 1</ambient>
          <diffuse>0.0 0.85 0.95 1</diffuse>
          <emissive>0.0 0.25 0.30 1</emissive>
        </material>
      </visual>

      <!-- Eye right -->
      <visual name="eye_right">
        <pose>0.174 -0.07 0.755 0 1.5707 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.006</length></cylinder></geometry>
        <material>
          <ambient>0.0 0.85 0.95 1</ambient>
          <diffuse>0.0 0.85 0.95 1</diffuse>
          <emissive>0.0 0.25 0.30 1</emissive>
        </material>
      </visual>

      <!-- Status bar — green strip at bottom of display (BL z=0.626) -->
      <visual name="head_status_bar">
        <pose>0.172 0 0.626 0 0 0</pose>
        <geometry><box><size>0.004 0.22 0.012</size></box></geometry>
        <material>
          <ambient>0.0 0.90 0.35 1</ambient>
          <diffuse>0.0 0.90 0.35 1</diffuse>
          <emissive>0.0 0.28 0.10 1</emissive>
        </material>
      </visual>

      <!-- ── Collisions ──────────────────────────────────────── -->
      <!-- Lower chassis box (for ground contact reactions) -->
      <collision name="chassis_col">
        <geometry><box><size>0.50 0.35 0.10</size></box></geometry>
      </collision>
      <!-- Upper tower box (obstacle avoidance, covers pillars + head) -->
      <collision name="tower_col">
        <pose>0 0 0.43 0 0 0</pose>
        <geometry><box><size>0.36 0.30 0.76</size></box></geometry>
      </collision>

      <!-- IMU — gyroscope fixes rotation drift during in-place turns -->
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <topic>/imu</topic>
        <ignition_frame_id>base_link</ignition_frame_id>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <!-- ════════════════════════════════════════════════════════════
         WHEELS (unchanged from original — physics and visuals)
    ════════════════════════════════════════════════════════════ -->

    <!-- ── FRONT LEFT  "/" rollers  fdir1 = 1 -1 0 ───────────── -->
    <link name="front_left_wheel">
      <pose>0.175 0.2 0.1 -1.5707 0 0</pose>
      <inertial><mass>0.5</mass><inertia>
        <ixx>0.001354</ixx><ixy>0</ixy><ixz>0</ixz>
        <iyy>0.001354</iyy><iyz>0</iyz><izz>0.002500</izz>
      </inertia></inertial>

      <visual name="frame"><geometry>
        <mesh><uri>model://mecanum_bot/meshes/wheel_frame.stl</uri></mesh>
      </geometry><material>
        <ambient>0.60 0.62 0.68 1</ambient><diffuse>0.60 0.62 0.68 1</diffuse>
        <specular>0.92 0.94 0.98 1</specular>
      </material></visual>

      <!-- 9 rubber rollers — FL/RR type (left=True) -->
      <visual name="rl0"><pose>0.07500 0.00000 0.0 -0.78540 0.00000 0.00000</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl1"><pose>0.05745 0.04821 0.0 -0.65369 -0.47183 0.16263</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl2"><pose>0.01302 0.07386 0.0 -0.17193 -0.77032 0.06985</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl3"><pose>-0.03750 0.06495 0.0 0.46365 -0.65906 -0.16112</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl4"><pose>-0.07048 0.02565 0.0 0.75432 -0.24427 -0.09717</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl5"><pose>-0.07048 -0.02565 0.0 0.75432 0.24427 0.09717</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl6"><pose>-0.03750 -0.06495 0.0 0.46365 0.65906 0.16112</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl7"><pose>0.01302 -0.07386 0.0 -0.17193 0.77032 -0.06985</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl8"><pose>0.05745 -0.04821 0.0 -0.65369 0.47183 -0.16263</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>

      <collision name="c"><geometry><sphere><radius>0.1</radius></sphere></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>0.0</mu2>
          <fdir1 ignition:expressed_in="base_link">1 -1 0</fdir1>
        </ode></friction></surface></collision>
    </link>

    <!-- ── FRONT RIGHT  "\" rollers  fdir1 = 1 1 0 ───────────── -->
    <link name="front_right_wheel">
      <pose>0.175 -0.2 0.1 -1.5707 0 0</pose>
      <inertial><mass>0.5</mass><inertia>
        <ixx>0.001354</ixx><ixy>0</ixy><ixz>0</ixz>
        <iyy>0.001354</iyy><iyz>0</iyz><izz>0.002500</izz>
      </inertia></inertial>

      <visual name="frame"><geometry>
        <mesh><uri>model://mecanum_bot/meshes/wheel_frame.stl</uri></mesh>
      </geometry><material>
        <ambient>0.60 0.62 0.68 1</ambient><diffuse>0.60 0.62 0.68 1</diffuse>
        <specular>0.92 0.94 0.98 1</specular>
      </material></visual>

      <!-- 9 rubber rollers — FR/RL type (left=False) -->
      <visual name="rl0"><pose>0.07500 0.00000 0.0 -2.35619 -0.00000 0.00000</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>

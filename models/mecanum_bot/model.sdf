      <visual name="rl2"><pose>0.01302 0.07386 0.0 -2.96966 -0.77032 2.72268</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl3"><pose>-0.03750 0.06495 0.0 2.67795 -0.65906 -1.93327</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl4"><pose>-0.07048 0.02565 0.0 2.38728 -0.24427 -0.60096</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl5"><pose>-0.07048 -0.02565 0.0 2.38728 0.24427 0.60096</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl6"><pose>-0.03750 -0.06495 0.0 2.67795 0.65906 1.93327</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl7"><pose>0.01302 -0.07386 0.0 -2.96966 0.77032 -2.72268</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl8"><pose>0.05745 -0.04821 0.0 -2.48790 0.47183 -1.23363</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>

      <collision name="c"><geometry><sphere><radius>0.1</radius></sphere></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>0.0</mu2>
          <fdir1 ignition:expressed_in="base_link">1 1 0</fdir1>
        </ode></friction></surface></collision>
    </link>

    <!-- ── REAR LEFT  "\" rollers  fdir1 = 1 1 0 ─────────────── -->
    <link name="rear_left_wheel">
      <pose>-0.175 0.2 0.1 -1.5707 0 0</pose>
      <inertial><mass>0.5</mass><inertia>
        <ixx>0.001354</ixx><ixy>0</ixy><ixz>0</ixz>
        <iyy>0.001354</iyy><iyz>0</iyz><izz>0.002500</izz>
      </inertia></inertial>

      <visual name="frame"><geometry>
        <mesh><uri>model://mecanum_bot/meshes/wheel_frame.stl</uri></mesh>
      </geometry><material>
        <ambient>0.60 0.62 0.68 1</ambient><diffuse>0.60 0.62 0.68 1</diffuse>
        <specular>0.92 0.94 0.98 1</specular>
      </material></visual>

      <!-- FR/RL type -->
      <visual name="rl0"><pose>0.07500 0.00000 0.0 -2.35619 -0.00000 0.00000</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl1"><pose>0.05745 0.04821 0.0 -2.48790 -0.47183 1.23363</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl2"><pose>0.01302 0.07386 0.0 -2.96966 -0.77032 2.72268</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl3"><pose>-0.03750 0.06495 0.0 2.67795 -0.65906 -1.93327</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl4"><pose>-0.07048 0.02565 0.0 2.38728 -0.24427 -0.60096</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl5"><pose>-0.07048 -0.02565 0.0 2.38728 0.24427 0.60096</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl6"><pose>-0.03750 -0.06495 0.0 2.67795 0.65906 1.93327</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl7"><pose>0.01302 -0.07386 0.0 -2.96966 0.77032 -2.72268</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl8"><pose>0.05745 -0.04821 0.0 -2.48790 0.47183 -1.23363</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>

      <collision name="c"><geometry><sphere><radius>0.1</radius></sphere></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>0.0</mu2>
          <fdir1 ignition:expressed_in="base_link">1 1 0</fdir1>
        </ode></friction></surface></collision>
    </link>

    <!-- ── REAR RIGHT  "/" rollers  fdir1 = 1 -1 0 ───────────── -->
    <link name="rear_right_wheel">
      <pose>-0.175 -0.2 0.1 -1.5707 0 0</pose>
      <inertial><mass>0.5</mass><inertia>
        <ixx>0.001354</ixx><ixy>0</ixy><ixz>0</ixz>
        <iyy>0.001354</iyy><iyz>0</iyz><izz>0.002500</izz>
      </inertia></inertial>

      <visual name="frame"><geometry>
        <mesh><uri>model://mecanum_bot/meshes/wheel_frame.stl</uri></mesh>
      </geometry><material>
        <ambient>0.60 0.62 0.68 1</ambient><diffuse>0.60 0.62 0.68 1</diffuse>
        <specular>0.92 0.94 0.98 1</specular>
      </material></visual>

      <!-- FL/RR type -->
      <visual name="rl0"><pose>0.07500 0.00000 0.0 -0.78540 0.00000 0.00000</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl1"><pose>0.05745 0.04821 0.0 -0.65369 -0.47183 0.16263</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl2"><pose>0.01302 0.07386 0.0 -0.17193 -0.77032 0.06985</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl3"><pose>-0.03750 0.06495 0.0 0.46365 -0.65906 -0.16112</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl4"><pose>-0.07048 0.02565 0.0 0.75432 -0.24427 -0.09717</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl5"><pose>-0.07048 -0.02565 0.0 0.75432 0.24427 0.09717</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl6"><pose>-0.03750 -0.06495 0.0 0.46365 0.65906 0.16112</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl7"><pose>0.01302 -0.07386 0.0 -0.17193 0.77032 -0.06985</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>
      <visual name="rl8"><pose>0.05745 -0.04821 0.0 -0.65369 0.47183 -0.16263</pose><geometry><mesh><uri>model://mecanum_bot/meshes/mecanum_roller.stl</uri></mesh></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.05 0.05 0.05 1</specular></material></visual>

      <collision name="c"><geometry><sphere><radius>0.1</radius></sphere></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>0.0</mu2>
          <fdir1 ignition:expressed_in="base_link">1 -1 0</fdir1>
        </ode></friction></surface></collision>
    </link>

    <!-- ════════════════════════════════════════════════════════════
         LIDAR — model frame z=0.98 (on top of head)
         base_link local z = 0.98 - 0.15 = 0.83
    ════════════════════════════════════════════════════════════ -->
    <link name="lidar_link">
      <pose>0 0 0.98 0 0 0</pose>
      <inertial><mass>0.15</mass><inertia>
        <ixx>0.0002</ixx><ixy>0</ixy><ixz>0</ixz>
        <iyy>0.0002</iyy><iyz>0</iyz><izz>0.0002</izz>
      </inertia></inertial>

      <!-- LiDAR housing — dark red cylinder -->
      <visual name="body">
        <geometry><cylinder><radius>0.050</radius><length>0.040</length></cylinder></geometry>
        <material>
          <ambient>0.75 0.06 0.06 1</ambient>
          <diffuse>0.80 0.08 0.08 1</diffuse>
          <specular>0.30 0.05 0.05 1</specular>
        </material>
      </visual>
      <!-- Scanning window ring -->
      <visual name="ring">
        <pose>0 0 0.022 0 0 0</pose>
        <geometry><cylinder><radius>0.042</radius><length>0.005</length></cylinder></geometry>
        <material>
          <ambient>0.04 0.04 0.04 1</ambient>
          <diffuse>0.04 0.04 0.04 1</diffuse>
        </material>
      </visual>
      <collision name="c">
        <geometry><cylinder><radius>0.050</radius><length>0.040</length></cylinder></geometry>
      </collision>

      <sensor name="lidar_sensor" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <update_rate>10</update_rate>
        <topic>/scan</topic>
        <ignition_frame_id>lidar_link</ignition_frame_id>
        <lidar>
          <scan><horizontal>
            <samples>360</samples><resolution>1</resolution>
            <min_angle>-3.14159265</min_angle><max_angle>3.14159265</max_angle>
          </horizontal></scan>
          <range><min>0.12</min><max>10.0</max><resolution>0.01</resolution></range>
          <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
        </lidar>
        <always_on>1</always_on><visualize>true</visualize>
      </sensor>
    </link>

    <!-- ════════════════════════════════════════════════════════════
         JOINTS
    ════════════════════════════════════════════════════════════ -->
    <joint name="front_left_wheel_joint"  type="revolute">
      <parent>base_link</parent><child>front_left_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit></axis>
    </joint>
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent><child>front_right_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit></axis>
    </joint>
    <joint name="rear_left_wheel_joint"   type="revolute">
      <parent>base_link</parent><child>rear_left_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit></axis>
    </joint>
    <joint name="rear_right_wheel_joint"  type="revolute">
      <parent>base_link</parent><child>rear_right_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit></axis>
    </joint>
    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent><child>lidar_link</child>
    </joint>

    <!-- ════════════════════════════════════════════════════════════
         PLUGINS
    ════════════════════════════════════════════════════════════ -->
    <plugin filename="ignition-gazebo-mecanum-drive-system"
            name="ignition::gazebo::systems::MecanumDrive">
      <front_left_joint>front_left_wheel_joint</front_left_joint>
      <front_right_joint>front_right_wheel_joint</front_right_joint>
      <back_left_joint>rear_left_wheel_joint</back_left_joint>
      <back_right_joint>rear_right_wheel_joint</back_right_joint>
      <wheel_separation>0.4</wheel_separation>
      <wheelbase>0.35</wheelbase>
      <wheel_radius>0.1</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_publish_frequency>50</odom_publish_frequency>
      <min_acceleration>-5</min_acceleration>
      <max_acceleration>5</max_acceleration>
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <plugin filename="ignition-gazebo-joint-state-publisher-system"
            name="ignition::gazebo::systems::JointStatePublisher"/>

  </model>
</sdf>
